{
  manifest_version: "0.1.0",

  // AgentBeats deploy-time configuration.
  config_schema: {
    type: "object",
    properties: {
      llm_model: { type: "string", default: "gpt-5-mini" },
      openai_api_key: { type: "string", secret: true },
    },
    required: [],
    additionalProperties: false,
  },

  // Runtime configuration.
  program: {
    // Replace this with the published public image before registration.
    image: "ghcr.io/jenova13q/j13_agentbeats-purple-agent:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9009",

    env: {
      LLM_MODEL: "${config.llm_model}",
      OPENAI_API_KEY: "${config.openai_api_key}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
